# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Mock Mode ────────────────────────────────────────────────────────────────
# Set to "true" to run fully simulated (no real API calls). Set "false" to go live.
MOCK_MODE=true

# ─── HubSpot ──────────────────────────────────────────────────────────────────
# Create a Private App in HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.deals.write, crm.schemas.read
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Vapi.ai (Voice Agents) ───────────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# ─── Twilio (SMS) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid_here

# ─── Gmail API ────────────────────────────────────────────────────────────────
# Download OAuth2 credentials JSON from Google Cloud Console
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3001/oauth2callback
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-crm

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0XXXXXXXX

# ─── Calendly ─────────────────────────────────────────────────────────────────
CALENDLY_WEBHOOK_SIGNING_KEY=your_calendly_signing_key_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ─── Redis (for BullMQ job queue) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Reporting (SMTP for weekly email reports) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ─── Default Client ───────────────────────────────────────────────────────────
# Which client config to use when no X-Client-ID header is provided
DEFAULT_CLIENT_ID=client_logistics
