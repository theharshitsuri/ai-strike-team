# ============================================================
# AI Strike Team — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# --- LLM Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default model to use: "openai" or "anthropic"
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/aistrikedb

# --- Logging ---
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json         # json | text

# --- Email Connector (optional, for email-based triggers) ---
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=your@email.com
EMAIL_PASSWORD=app-specific-password

# --- Slack (optional, for Slack action layer) ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...

# --- Workflow Settings ---
# Max tokens to send to LLM per request
MAX_TOKENS=4096
# Confidence threshold below which to flag for human review (0.0–1.0)
CONFIDENCE_THRESHOLD=0.75
# Number of retries on LLM call failure
LLM_RETRY_COUNT=3
